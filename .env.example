# Guild Book — Environment Variables

# Auth (required for production)
AUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:5173
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Set to true to enable the dev-only Credentials login provider (also requires
# NODE_ENV=development). Off by default so a leaked dev deployment cannot
# accept arbitrary email logins.
AUTH_DEV_LOGIN=false

# Dev-only auto-login pass-through. Skips the /login screen entirely and signs
# you in as `dev@local` on first request. Requires NODE_ENV=development AND the
# gitignored src/lib/server/dev-auto-login.ts file (copy from
# dev-auto-login.example.ts to enable). Off by default. NEVER set true in
# production — even if set, the bypass file is gitignored and absent there.
AUTH_DEV_AUTOLOGIN=false

# Database (default: local.db in project root)
DATABASE_URL=local.db

# Campaign foundation rollout (server-only; disabled by default). Access is
# granted when CAMPAIGNS_ENABLED is true OR the signed-in user's id is in
# CAMPAIGNS_PILOT_USER_IDS (comma-separated Guild Book user ids, not emails).
# For an allowlisted pilot, keep CAMPAIGNS_ENABLED=false and populate only
# the pilot list — see docs/operations/campaign-pilot.md for how to look up
# a pilot user's id, the session start/freeze/recover/end operator flow, the
# privacy incident response, and the feature-disable rollback (both scopes:
# revoke one id, or clear the pilot entirely).
CAMPAIGNS_ENABLED=false
CAMPAIGNS_PILOT_USER_IDS=
CAMPAIGN_INVITE_SECRET=generate-a-dedicated-campaign-invite-secret

# Build/server
ADAPTER=auto
NODE_ENV=development
ORIGIN=http://localhost:5173
PORT=3000
